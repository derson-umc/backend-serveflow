APPLICATION_NAME=serveflow
SERVER_PORT=8080

# URL base da aplicação
APP_BASE_URL=http://localhost:8080/api

# Banco de dados
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=serveflow_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=

# PgAdmin
PGADMIN_DEFAULT_EMAIL=admin@serveflow.com.br
PGADMIN_DEFAULT_PASSWORD=
PGADMIN_PORT=5050

# JWT
JWT_SECRET=
JWT_EXPIRATION=28800000

# Usuário root
ROOT_USERNAME=root
ROOT_PASSWORD=

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ViaCEP
VIACEP_URL=https://viacep.com.br/ws/{cep}/json/

# E-mail (Gmail SMTP)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

APP_UPLOAD_MAX_DIMENSION=1200
APP_UPLOAD_JPEG_QUALITY=0.82
