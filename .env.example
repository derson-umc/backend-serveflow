APPLICATION_NAME=serveflow
SERVER_PORT=8080

# ─── URL base da aplicação ────────────────────────────────────
# Usado para montar URLs de imagens salvas no banco.
# NÃO inclua /uploads no final — o sufixo /images é adicionado automaticamente.
# Local:  http://localhost:8080/api
# Render: https://SEU-SERVICO.onrender.com/api
APP_BASE_URL=http://localhost:8080/api

# ─── Banco de dados ───────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=serveflow_db

# Usuário da aplicação (deve ter RLS aplicado — NÃO use postgres em prod)
# Dev local: pode usar postgres. Prod/Staging: use serveflow_backend
POSTGRES_USER=postgres
POSTGRES_PASSWORD=

# Usuário do Flyway (superuser — necessário para DDL migrations)
# Prod: use o usuário postgres do Supabase separado do usuário da aplicação
POSTGRES_FLYWAY_USER=postgres
POSTGRES_FLYWAY_PASSWORD=

# ─── PgAdmin ──────────────────────────────────────────────────
PGADMIN_DEFAULT_EMAIL=admin@serveflow.com.br
PGADMIN_DEFAULT_PASSWORD=
PGADMIN_PORT=5050

# ─── JWT ──────────────────────────────────────────────────────
JWT_SECRET=
JWT_EXPIRATION=86400000

# ─── Usuário root ─────────────────────────────────────────────
ROOT_USERNAME=root
ROOT_PASSWORD=

# ─── CORS / Frontend ──────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ─── Integração ViaCEP ────────────────────────────────────────
VIACEP_URL=https://viacep.com.br/ws/{cep}/json/

# ─── E-mail (Gmail SMTP) ──────────────────────────────────────
# MAIL_PASSWORD: usar App Password do Google (não a senha da conta)
# Gerar em: https://myaccount.google.com/apppasswords
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=

# ─── Cloudinary (upload de imagens em produção) ───────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

APP_UPLOAD_MAX_DIMENSION=1200
APP_UPLOAD_JPEG_QUALITY=0.82